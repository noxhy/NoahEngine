; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Friday Night Funkin': Noah Engine"
config/version="3.2.0"
run/main_scene="uid://crfoqsmbdm5bd"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="uid://dr2pbdp8x8xpb"

[audio]

buses/default_bus_layout="uid://wp1fb3lbqup6"

[autoload]

Global="*res://noah/global.tscn"
Transitions="*res://noah/transitions.tscn"
GameManager="*res://noah/managers/game_manager.gd"
Preload="*uid://cnqn5donqdijf"
SettingsManager="*res://noah/managers/settings_manager.gd"
ChartManager="*res://noah/managers/chart_manager.gd"
SoundManager="*res://noah/managers/sound_manager.tscn"
SaveManager="*res://noah/managers/save_manager.gd"
Signals="*res://noah/signals.gd"
Constants="*uid://dctyx01j6jvbu"

[debug]

gdscript/warnings/unused_parameter=0
gdscript/warnings/integer_division=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/gdanimate-rewrite-main/plugin.cfg", "res://addons/parallax2d_preview/plugin.cfg")

[file_customization]

folder_colors={
"res://noah/": "purple",
"res://noah/assets/": "yellow",
"res://noah/game/": "red",
"res://noah/managers/": "pink",
"res://noah/resources/": "green",
"res://noah/tools/": "gray"
}

[global_group]

player="The characters that should play an animation when the player notes are played"
enemy="The characters that should play an animation when the enemy notes are played"
metronome="the characters that should play an animations every other beat (gf)"
camera_positions="Camera positions for playstate"

